---
import '@fontsource-variable/dm-sans';
---

<style is:inline>
  :root {
    --aw-font-sans: 'DM Sans Variable';
    --aw-font-serif: 'DM Sans Variable';
    --aw-font-heading: 'DM Sans Variable';

    --aw-color-primary: rgb(255 81 81);
    --aw-color-secondary: rgb(35 35 35);
    --aw-color-accent: rgb(4 0 154);

    --aw-color-text-heading: rgb(13 13 13);
    --aw-color-text-default: rgb(35 35 35);
    --aw-color-text-muted: rgb(71 71 71);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(13 13 13);

    ::selection {
      background-color: rgb(255 81 81 / 20%);
    }
  }

  .dark {
    --aw-font-sans: 'DM Sans Variable';
    --aw-font-serif: 'DM Sans Variable';
    --aw-font-heading: 'DM Sans Variable';

    --aw-color-primary: rgb(255 81 81);
    --aw-color-secondary: rgb(35 35 35);
    --aw-color-accent: rgb(4 0 154);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(13 13 13);

    ::selection {
      background-color: rgb(255 81 81 / 30%);
      color: snow;
    }
  }
</style>
