---
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro';
import { hero } from '~/i18n/translations';

const metadata = {
  title: 'BgGPT',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <section class="relative not-prose">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="py-12 md:py-20">
        <div class="text-center max-w-5xl mx-auto">
          <h1 class="text-4xl md:text-5xl font-bold leading-tight tracking-tighter mb-8 font-heading dark:text-gray-200">
            <span data-lang-en style="display:none" set:html={hero.en.title} />
            <span data-lang-bg set:html={hero.bg.title} />
          </h1>
          <div class="m-auto flex justify-center" data-lang-en style="display:none">
            <Button variant="primary" text={hero.en.cta} href="mailto:bggpt@insait.ai" icon="tabler:mail" />
          </div>
          <div class="m-auto flex justify-center" data-lang-bg>
            <Button variant="primary" text={hero.bg.cta} href="mailto:bggpt@insait.ai" icon="tabler:mail" />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
